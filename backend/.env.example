# ── Groq LLM ──────────────────────────────────────────────
# Get your free API key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Model — llama-3.3-70b-versatile is recommended (fast + accurate)
GROQ_MODEL=llama-3.3-70b-versatile

# ── File Storage ───────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# ── Database ───────────────────────────────────────────────
# SQLite (default, zero config) — path relative to backend/
DATABASE_URL=sqlite:///resume_screener.db

# ── ChromaDB ───────────────────────────────────────────────
# Local persistent vector store — no external service needed
CHROMA_PERSIST_DIR=chroma_db

# ── CORS (production) ─────────────────────────────────────
# Set to your Vercel frontend URL in production
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app
